{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lab/contracts": ["packages/contracts/src/index.ts"],
      "@lab/branding": ["packages/branding/src/index.ts"],
      "@lab/ui": ["packages/ui/src/index.ts"],
      "@lab/demo-data": ["packages/demo-data/src/index.ts"]
    }
  }
}
