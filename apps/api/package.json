{
  "name": "@lab/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node -r ts-node/register/transpile-only -r tsconfig-paths/register src/main.ts",
    "start:dev": "npm run start",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "TS_NODE_PROJECT=tsconfig.json node --test -r ts-node/register/transpile-only -r tsconfig-paths/register test/*.test.ts"
  },
  "dependencies": {
    "@lab/branding": "0.1.0",
    "@lab/contracts": "0.1.0",
    "@lab/demo-data": "0.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
